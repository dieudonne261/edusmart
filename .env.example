# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  EDUSMART — Modèle des variables d'environnement                          ║
# ║                                                                            ║
# ║  Copie ce fichier en `.env` à la racine et remplace les <placeholders>    ║
# ║  par les vraies valeurs.                                                   ║
# ║                                                                            ║
# ║  ⚠️  Ne JAMAIS commiter le fichier `.env` (déjà dans .gitignore).         ║
# ║  ⚠️  Tout secret poussé une fois sur GitHub est considéré compromis       ║
# ║      → régénérer dans les dashboards respectifs.                          ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
# URL du projet (utilisée par toutes les apps, côté client et serveur)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
# Clé legacy anon (JWT) — utilisée par @supabase/supabase-js v2 et @supabase/ssr
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-jwt>
# Clé publique nouveau format (sb_publishable_...) — optionnel, futur usage
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-sb_publishable_key>
# Clé service_role legacy (JWT) — BYPASS RLS — SERVEUR UNIQUEMENT
SUPABASE_SERVICE_ROLE_KEY=<server-only-jwt-secret>
# Clé secrète nouveau format (sb_secret_...) — équivalent service_role
SUPABASE_SECRET_KEY=<server-only-sb_secret_key>

# ─── IA (OpenRouter) ───────────────────────────────────────────────────────────
# Accès multi-modèles : Claude Haiku / Mistral / Claude 3.5 Sonnet
OPENROUTER_API_KEY=<your-openrouter-api-key>

# ─── Emails transactionnels (Resend) ───────────────────────────────────────────
# 3000 mails/mois gratuits, région EU
RESEND_API_KEY=<your-resend-api-key>

# ─── SMS ───────────────────────────────────────────────────────────────────────
# Twilio (international, plus cher)
TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_PHONE_NUMBER=+14155552671
# Africa's Talking (préféré pour les coûts Madagascar)
AFRICASTALKING_USERNAME=<your-at-username>
AFRICASTALKING_API_KEY=<your-at-api-key>

# ─── Domaine & callback ────────────────────────────────────────────────────────
# Domaine racine — sert au middleware multi-tenant pour parser le sous-domaine
NEXT_PUBLIC_ROOT_DOMAIN=edusmart.site
# URL de callback de NOTRE app (à utiliser dans les Server Actions OAuth).
# /!\ NE PAS confondre avec le callback INTERNE Supabase (auto-configuré).
NEXT_PUBLIC_SUPABASE_AUTH_CALLBACK_URL=https://edusmart.site/auth/callback
